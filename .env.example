# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://mcpforge:mcpforge_dev@localhost:5432/mcpforge

# ─── Redis / Queue ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-generate-a-real-secret-minimum-32-bytes
ENCRYPTION_KEY=change-me-generate-a-real-encryption-key-32b

# ─── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4300
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4

# ─── AI Provider ──────────────────────────────────────────────────────────────
AI_PROVIDER=mock
AI_MODEL=mock

# ─── Object Storage ───────────────────────────────────────────────────────────
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=mcpforge-artifacts
# LOCAL DEV ONLY — change to real credentials for staging/production
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

# ─── Web (Vite) ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4300
