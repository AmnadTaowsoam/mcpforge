{
  "name": "mcpforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Create production-ready MCP server templates from a single command or guided setup flow",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:visual": "turbo run test:visual",
    "test:golden": "turbo run test:golden",
    "audit": "pnpm audit --audit-level=high",
    "db:up": "docker compose up -d postgres redis minio",
    "db:migrate": "pnpm --filter @mcpforge/api run db:migrate",
    "db:seed": "pnpm --filter @mcpforge/api run db:seed",
    "worker:dev": "pnpm --filter @mcpforge/worker run dev",
    "queue:inspect": "pnpm --filter @mcpforge/worker run queue:inspect",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.1"
  },
  "packageManager": "pnpm@9.15.0"
}
