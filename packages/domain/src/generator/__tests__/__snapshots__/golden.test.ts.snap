exports[`Golden-file snapshots — TypeScript REST > readme matches snapshot 1`] = `
"# Stripe MCP Server

Stripe payment connector

Generated by [MCPForge](https://mcpforge.dev) on <TIMESTAMP>.

## Quick start

\`\`\`bash
npm install
npm run build
node dist/index.js
\`\`\`

## Tools

| Tool | Description |
|---|---|
| \`Stripe_list\` | List resources (optional \`query\` filter) |
| \`Stripe_get\` | Get a resource by \`id\` |

## Configuration

| Variable | Description | Required |
|---|---|---|
| \`MCP_SERVER_NAME\` | Override the server name | No |
"
`;

exports[`Golden-file snapshots — TypeScript REST > server code matches snapshot 1`] = `
"import { McpServer } from '@modelcontextprotocol/sdk/server/mcp.js'
import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js'
import { z } from 'zod'

// Features: pagination
const server = new McpServer({
  name: 'Stripe',
  version: '1.0.0',
})

server.tool(
  'Stripe_list',
  { query: z.string().optional() },
  async ({ query }) => ({
    content: [
      {
        type: 'text' as const,
        text: JSON.stringify({ connector: 'Stripe', query, results: [] }),
      },
    ],
  }),
)

server.tool(
  'Stripe_get',
  { id: z.string() },
  async ({ id }) => ({
    content: [
      {
        type: 'text' as const,
        text: JSON.stringify({ connector: 'Stripe', id, data: null }),
      },
    ],
  }),
)

const transport = new StdioServerTransport()
await server.connect(transport)
"
`;

exports[`Golden-file snapshots — TypeScript REST > test stub matches snapshot 1`] = `
"import { describe, it, expect } from 'vitest'

// Inline tool handlers extracted for testing — mirrors the implementation in src/index.ts.
const list_stripe = async ({ query }: { query?: string }) => ({
  content: [{ type: 'text' as const, text: JSON.stringify({ connector: 'Stripe', query, results: [] }) }],
})

const get_stripe = async ({ id }: { id: string }) => ({
  content: [{ type: 'text' as const, text: JSON.stringify({ connector: 'Stripe', id, data: null }) }],
})

describe('Stripe MCP server tools', () => {
  it('Stripe_list returns a content array', async () => {
    const result = await list_stripe({ query: 'test' })
    expect(Array.isArray(result.content)).toBe(true)
    expect(result.content[0]?.type).toBe('text')
  })

  it('Stripe_list response body contains connector name and results array', async () => {
    const result = await list_stripe({ query: 'hello' })
    const body = JSON.parse(result.content[0]?.text ?? '{}') as { connector: string; results: unknown[] }
    expect(body.connector).toBe('Stripe')
    expect(Array.isArray(body.results)).toBe(true)
  })

  it('Stripe_get returns content with matching id', async () => {
    const result = await get_stripe({ id: 'test-id' })
    const body = JSON.parse(result.content[0]?.text ?? '{}') as { connector: string; id: string; data: unknown }
    expect(body.id).toBe('test-id')
    expect(body.connector).toBe('Stripe')
    expect('data' in body).toBe(true)
  })
})
"
`;
